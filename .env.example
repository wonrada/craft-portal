# ── Nginx ────────────────────────────────────────────────────────────────────
# Port exposed on the host for the nginx reverse proxy
NGINX_PORT=80

# ── MySQL ────────────────────────────────────────────────────────────────────
# These values must match the DB_* variables in backend/.env
DB_DATABASE=craft_portal
DB_ROOT_PASSWORD=secret
DB_USERNAME=craft
DB_PASSWORD=secret

# Port exposed on the host to connect to MySQL directly (e.g. with a GUI client)
DB_EXPOSE_PORT=3306
